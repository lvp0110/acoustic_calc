# ── Рантайм server.js (прод, внутри контейнера) ───────────────
# Порт, на котором express слушает HTTP внутри контейнера.
HTTP_PORT=3000
# Бэкенд, куда server.js проксирует /api (server-side, в браузер не утекает).
# Без суффикса /api — только origin, напр. https://dev3.constrtodo.ru:3005
BASE_URL=https://dev3.constrtodo.ru:3005

# ── Локальная разработка (vite dev) ──────────────────────────
# Оставь ПУСТЫМ, чтобы фронт ходил в относительный /api через прокси.
# В проде НЕ задаём (фронт собирается без него и ходит в /api).
# VITE_BASE_URL=
